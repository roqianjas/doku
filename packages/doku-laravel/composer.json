{
    "name": "local/doku-laravel",
    "description": "Reusable Laravel-first integration for DOKU Checkout.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "DokuLaravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DokuLaravel\\DokuServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
